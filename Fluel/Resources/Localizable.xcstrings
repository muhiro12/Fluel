    "Manage pinned, recent, and custom presets here so new entries begin closer to your usual shape.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Manage pinned, recent, and custom presets here so new entries begin closer to your usual shape."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Gestiona aquí los preajustes fijados, recientes y personalizados para que los registros nuevos empiecen más cerca de tu forma habitual."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Gérez ici les préréglages épinglés, récents et personnalisés pour que les nouvelles entrées démarrent plus près de votre forme habituelle."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在这里管理置顶、最近使用和自定义预设，让新建记录更接近你平时的习惯。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ピン留め、最近使ったもの、カスタムをここで整えると、新規作成が自分の形に近いところから始まります。"
          }
        }
      }

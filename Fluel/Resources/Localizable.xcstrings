    "Once entries are added, updated, or archived, the quiet history of those changes will gather here.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Once entries are added, updated, or archived, the quiet history of those changes will gather here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cuando se añadan, actualicen o archiven registros, el historial sereno de esos cambios se reunirá aquí."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une fois les entrées ajoutées, modifiées ou archivées, l’historique discret de ces changements se rassemblera ici."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "当记录被添加、更新或归档之后，这些变化的安静历史会汇集在这里。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "記録の追加、更新、保管が積もってくると、その静かな履歴がここに集まります。"
          }
        }
      }
    },

    "If you only know the month or year, switch the precision first. You can refine it later.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If you only know the month or year, switch the precision first. You can refine it later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Si solo conoces el mes o el año, cambia antes la precisión. Después podrás afinarla."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Si vous ne connaissez que le mois ou l’année, changez d’abord la précision. Vous pourrez l’affiner plus tard."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你只知道月份或年份，请先切换精度，之后仍然可以继续细化。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "日まで分からない時は、先に月や年へ切り替えられます。あとから細かく直すこともできます。"
          }
        }
      }
    },
    "Keep the next action close": {

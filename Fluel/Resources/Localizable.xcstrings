    "Choose one preset as the default when you want every new entry to open from the same starting point.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose one preset as the default when you want every new entry to open from the same starting point."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige un preajuste como predeterminado si quieres que cada nuevo registro se abra desde el mismo punto de partida."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez un préréglage par défaut si vous souhaitez que chaque nouvelle entrée s’ouvre depuis le même point de départ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果你希望每次新建记录都从相同的起点开始，可以选择一个预设作为默认值。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いつも近い形から始めたい時は、1 つを既定にすると新規作成がその内容で開きます。"
          }
        }
      }
    },

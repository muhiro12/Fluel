    "Begin from a familiar thing or place, then adjust anything you need.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Begin from a familiar thing or place, then adjust anything you need."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza desde una cosa o un lugar familiar y ajusta solo lo que necesites."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez à partir d’une chose ou d’un lieu familier, puis ajustez ce dont vous avez besoin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "从熟悉的物品或地点开始，再按需调整。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "身近なものや場所から始めて、必要なところだけ整えられます。"
          }
        }
      }
    },

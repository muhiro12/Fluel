        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Lee de nuevo la secuencia serena de registros añadidos, ajustados y archivados."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Relisez la suite discrète des entrées ajoutées, ajustées et archivées."

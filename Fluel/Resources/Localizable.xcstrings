    "Quick presets let you begin from a familiar shape before you adjust the details.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quick presets let you begin from a familiar shape before you adjust the details."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los preajustes rápidos te permiten empezar desde una forma conocida antes de ajustar los detalles."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les préréglages rapides vous permettent de commencer à partir d’une forme familière avant d’ajuster les détails."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "快速预设可以让你先从熟悉的形态开始，再去调整细节。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "クイックプリセットを使うと、よくある形から始めて必要なところだけ整えられます。"
          }
        }
      }
    },
    "Read back the quiet sequence of entries being added, adjusted, and archived.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Read back the quiet sequence of entries being added, adjusted, and archived."

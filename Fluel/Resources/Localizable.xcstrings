    "Archived entries stay here, separate from what you still live with every day.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Archived entries stay here, separate from what you still live with every day."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Los registros archivados se quedan aquí, aparte de lo que aún compartes a diario."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les entrées archivées restent ici, séparées de ce qui vous accompagne encore au quotidien."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已归档的记录会留在这里，与仍在日常陪伴你的那些记录分开显示。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "保管済みの記録は、いまも日々を一緒にしているものとは分けてここに残ります。"
          }
        }
      }
    },

{
  "sourceLanguage": "en",
  "strings": {
    "A quiet view of how long this has been with you.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A quiet view of how long this has been with you."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una vista serena del tiempo que esto ha estado contigo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une vue apaisée du temps passé à vos côtés."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "安静地看看它陪伴了你多久。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どれくらい長くそばにあるかを、落ち着いて見られます。"
          }
        }
      }
    },
    "A small note, if it matters.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A small note, if it matters."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Una nota breve, si hace falta."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une petite note, si besoin."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如果需要，可以留一小段备注。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "必要なら、短いメモを残せます。"
          }
        }
      }
    },
    "Add": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregar"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "追加"
          }
        }
      }
    },
    "Add a wallet, bag, shoes, watch, notebook, plant, furniture, or this home, and Fluel will quietly keep the time with it.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a wallet, bag, shoes, watch, notebook, plant, furniture, or this home, and Fluel will quietly keep the time with it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade una cartera, bolso, zapatos, reloj, cuaderno, planta, mueble o esta casa, y Fluel guardará en silencio el tiempo compartido."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez un portefeuille, un sac, des chaussures, une montre, un carnet, une plante, un meuble ou cette maison, et Fluel gardera discrètement le temps partagé."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加钱包、包、鞋子、手表、笔记本、植物、家具或这个家，Fluel 就会安静地记录与你相伴的时间。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "財布、バッグ、靴、腕時計、ノート、植物、家具、この家のように、一緒に暮らしているものや場所を登録すると、その時間が静かに積もっていきます。"
          }
        }
      }
    },
    "Add first entry": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add first entry"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Agregar el primer registro"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter la première entrée"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加第一条记录"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初の記録を追加"
          }
        }
      }
    },
    "Add one thing or place first. You can quietly refine the date or note later.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add one thing or place first. You can quietly refine the date or note later."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Empieza añadiendo una cosa o un lugar. Luego podrás ajustar con calma la fecha o la nota."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Commencez par ajouter une chose ou un lieu. Vous pourrez ensuite affiner tranquillement la date ou la note."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "先添加一件物品或一个地点就可以了，之后再慢慢调整日期或备注。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まずはものや場所を 1 件加えるだけで十分です。日付やメモはあとから静かに整えられます。"
          }
        }
      }
    },
    "Add one thing or place you live with.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add one thing or place you live with."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade una cosa o un lugar con el que convives."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez une chose ou un lieu avec lequel vous vivez."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加一件与你共同生活的物品或一个地点。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "一緒に暮らしているものや場所をひとつ加えます。"
          }
        }
      }
    },
    "Add the first entry and Fluel will start shaping the quiet overview here.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add the first entry and Fluel will start shaping the quiet overview here."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade el primer registro y Fluel empezará a dibujar aquí una vista general serena."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez la première entrée et Fluel commencera à former ici une vue d’ensemble apaisée."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加第一条记录后，Fluel 就会在这里慢慢形成安静的整体视图。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最初の記録を追加すると、ここに静かな全体像が立ち上がります。"
          }
        }
      }
    },

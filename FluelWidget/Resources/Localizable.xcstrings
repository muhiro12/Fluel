    "Add an entry in Fluel to quietly keep time with it.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add an entry in Fluel to quietly keep time with it."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade un registro en Fluel para conservar en silencio ese tiempo juntos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez une entrée dans Fluel pour conserver discrètement ce temps passé ensemble."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在 Fluel 中添加一条记录，安静地保存这段相伴时间。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Fluel で記録を追加すると、その時間が静かに見えてきます。"
          }
        }
      }
    },

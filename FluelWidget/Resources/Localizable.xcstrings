    "Shows your longest-running entry and nearby dashboard highlights.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Shows your longest-running entry and nearby dashboard highlights."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Muestra el registro que más tiempo lleva contigo y los puntos destacados cercanos del resumen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Affiche l’entrée qui vous accompagne depuis le plus longtemps et les points forts voisins du tableau de bord."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "显示陪伴你最久的记录，以及附近的概览重点。"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "いちばん長く一緒にいる記録と、その周辺の状況を表示します。"
          }
        }
      }
    },
